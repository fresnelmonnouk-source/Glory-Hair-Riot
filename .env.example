# Copier ce fichier en `.env.local` et remplir les valeurs.
# `.env.local` est ignoré par Git (.gitignore). Ne JAMAIS commiter de vraies clés ici.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Deepseek (ELODIE)
DEEPSEEK_API_KEY=your_deepseek_api_key

# Essai Live (Try-on IA) — JAMAIS exposer côté client (systeme.md §9.1)
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# FedaPay
FEDAPAY_SECRET_KEY=your_fedapay_secret_key
NEXT_PUBLIC_FEDAPAY_PUBLIC_KEY=your_fedapay_public_key
FEDAPAY_WEBHOOK_SECRET=your_fedapay_webhook_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Resend (Email)
RESEND_API_KEY=your_resend_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
